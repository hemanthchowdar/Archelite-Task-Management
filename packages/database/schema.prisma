datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AccessRole {
  super_admin
  admin
  member
}

enum OrgStatus {
  active
  inactive
}

enum Priority {
  low
  medium
  high
  critical
  urgent
}

enum TaskStatus {
  todo
  in_progress
  needs_action
  needs_verification
  closed
}

enum AssignmentRole {
  owner
  collaborator
}

enum CommentType {
  text
  voice
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model Employee {
  id                String       @id @default(uuid()) @db.Uuid
  name              String
  email             String       @unique
  phone             String       @unique
  employeeId        String       @unique
  photoUrl          String?
  accessRole        AccessRole   @default(member)
  orgLevel          Int          @default(1)
  address           String?
  dob               DateTime?
  bloodGroup        String?
  preferredLanguage String       @default("en")
  status            OrgStatus    @default(active)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  createdTasks            Task[]            @relation("CreatedBy")
  taskAssignments         TaskAssignment[]
  comments                Comment[]
  approvalRequestsCreated ApprovalRequest[] @relation("RequestedBy")
  approvalRequestsDecided ApprovalRequest[] @relation("DecidedBy")
  notifications           Notification[]
}

model Task {
  id             String     @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  priority       Priority   @default(medium)
  status         TaskStatus @default(todo)
  dueDate        DateTime?
  categoryId     String     @db.Uuid
  projectId      String?    @db.Uuid
  createdBy      String     @db.Uuid
  createdAt      DateTime   @default(now())
  lastActivityAt DateTime   @default(now())

  creator          Employee          @relation("CreatedBy", fields: [createdBy], references: [id])
  category         Category          @relation(fields: [categoryId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  assignments      TaskAssignment[]
  comments         Comment[]
  attachments      Attachment[]
  approvalRequests ApprovalRequest[]
  auditLogs        AuditLog[]
  notifications    Notification[]
}

model TaskAssignment {
  taskId     String         @db.Uuid
  employeeId String         @db.Uuid
  role       AssignmentRole @default(collaborator)
  assignedBy String         @db.Uuid
  assignedAt DateTime       @default(now())

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([taskId, employeeId])
}

model Comment {
  id        String      @id @default(uuid()) @db.Uuid
  taskId    String      @db.Uuid
  authorId  String      @db.Uuid
  body      String
  type      CommentType @default(text)
  createdAt DateTime    @default(now())

  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      Employee     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[]
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  taskId     String?  @db.Uuid
  commentId  String?  @db.Uuid
  uploaderId String   @db.Uuid
  fileUrl    String
  fileType   String
  fileName   String
  sizeBytes  Int

  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
}

model ApprovalRequest {
  id              String         @id @default(uuid()) @db.Uuid
  taskId          String         @db.Uuid
  requestedById   String         @db.Uuid
  approverId      String         @db.Uuid
  status          ApprovalStatus @default(pending)
  decisionComment String?
  decidedAt       DateTime?
  createdAt       DateTime       @default(now())

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requestedBy Employee @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approver    Employee @relation("DecidedBy", fields: [approverId], references: [id], onDelete: Cascade)
}

model Category {
  id           String @id @default(uuid()) @db.Uuid
  key          String @unique
  translations Json   @default("{}")

  tasks Task[]
}

model Project {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  location String?

  tasks Task[]
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  actorId   String   @db.Uuid
  action    String
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  type       String
  taskId     String?  @db.Uuid
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}
